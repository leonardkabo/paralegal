rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(phoneOrId) {
      return isAuthenticated() && (
        request.auth.uid == phoneOrId ||
        request.auth.token.email == phoneOrId ||
        request.auth.token.email == phoneOrId + "@paralegal.bj"
      );
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "leonardkabo32@gmail.com" ||
        request.auth.token.email == "healthaccessinitiativehai@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.token.email)) && 
         get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.isAdmin == true)
      );
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.fullName is string && data.fullName.size() > 0 &&
             data.phone is string && data.phone.size() > 0;
    }

    function isValidProgress(data) {
      return data.keys().hasAny(['completedModules', 'quizScores']);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow get: if true;
      allow list: if isAuthenticated() && (isOwner(userId) || isAdmin());
      // Special case: allow registration (create) if data is valid
      allow create: if isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /progress/{userId} {
      allow get: if true;
      allow list: if isAuthenticated() && (isOwner(userId) || isAdmin());
      // Allow creation during registration or by admin
      allow create: if isValidProgress(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    match /modules/{moduleId} {
      allow read: if true; // Modules are public content
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    match /settings/{key} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /glossary/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /legal_documents/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /case_studies/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
