rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Deny-All (Pillar 0)
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Shared Helpers (Phase 3)
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && (
        request.auth.uid == userId || 
        request.auth.token.email == userId ||
        request.auth.token.email == userId + "@paralegal.bj"
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "leonardkabo32@gmail.com" ||
        request.auth.token.email == "healthaccessinitiativehai@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.token.email)) && 
         get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.isAdmin == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_+@.\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      // PII Protection: Only owner or admin can read specific user profile
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      // Validation for creation
      allow create: if isSignedIn() && (isOwner(userId) || isAdmin()) &&
        incoming().fullName is string && 
        incoming().fullName.size() > 0 &&
        incoming().fullName.size() < 100 &&
        (incoming().isAdmin == false || isAdmin()); // Prevent self-elevation
        
      allow update: if (isOwner(userId) || isAdmin()) && (
        isAdmin() || 
        (!incoming().diff(existing()).affectedKeys().hasAny(['isAdmin']) && incoming().isAdmin == existing().isAdmin)
      );
    }

    match /progress/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && isValidId(userId);
      allow update: if (isOwner(userId) || isAdmin()) && isValidId(userId);
    }

    match /modules/{moduleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      // Anyone authenticated can create a report
      allow create: if isSignedIn() && isValidId(reportId);
      // Only admin or the creator can read the report
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /settings/{key} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /glossary/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /legal_documents/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /case_studies/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
